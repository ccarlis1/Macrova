# User Profile Configuration
# Copy this file to user_profile.yaml and customize for your needs

nutrition_goals:
  # Daily calorie target
  daily_calories: 2400
  
  # OPTIONAL: Hard maximum daily calorie limit (Calorie Deficit Mode)
  # When set, meal plans exceeding this value are rejected (hard constraint)
  # Uncomment to enable:
  # max_daily_calories: 2200
  
  # Protein target (grams per day)
  # Based on 0.7-0.8g per pound bodyweight (from knowledge.md)
  daily_protein_g: 138
  
  # Fat target range (grams per day)
  # From knowledge.md: 50-100g range, median ~75g
  daily_fat_g:
    min: 65
    max: 85
  
  # Carbs are calculated automatically:
  # carbs = (calories - protein*4 - fat*9) / 4
  # Using median fat (75g) for calculation:
  # carbs = (2400 - 150*4 - 75*9) / 4 = (2400 - 600 - 675) / 4 = 281g

schedule:
  # Format: "HH:MM": busyness_level
  # Busyness levels:
  #   1 = snack (< 5 minutes)
  #   3 = weeknight meal (≤ 30 minutes)
  #   4 = weekend/meal prep (30+ minutes)
  # Note: The first 3 times are treated as breakfast, lunch, dinner (in order)
  # Any 4th time is treated as workout time
  
  # Example schedule - adjust to your routine
  "07:00": 2 # Morning: quick meal (breakfast)
  "12:00": 2 # Lunch: weeknight meal
  "18:00": 2 # Dinner: snack
  "08:00": 0 # Workout time

preferences:
  # Foods you like (will be prioritized in recommendations)
  liked_foods:
    - "salmon"
    - "rice"
    - "potatoes"
    - "chicken"
    - "turkey"
    - "spinach"
    - "peppers"
  
  # Foods you dislike (will be avoided)
  disliked_foods:
    - "brussels sprouts"
    - "liver"
    - "anchovies"
  
  # Allergens (will be strictly avoided)
  allergies:
    - "shellfish"
    - "peanuts"

# Daily RDI targets (previously weekly_targets with values = daily × 7)
micronutrient_goals:
  # Vitamins
  vitamin_a_ug: 900      # was 6300 weekly
  vitamin_c_mg: 90       # was 630 weekly
  vitamin_d_iu: 600      # was 4200 weekly
  vitamin_e_mg: 15       # was 105 weekly
  vitamin_k_ug: 120      # was 840 weekly
  b1_thiamine_mg: 1.2    # was 8.4 weekly
  b2_riboflavin_mg: 1.3 # was 9.1 weekly
  b3_niacin_mg: 16      # was 112 weekly
  b5_pantothenic_acid_mg: 5    # was 35 weekly
  b6_pyridoxine_mg: 1.3 # was 9.1 weekly
  b12_cobalamin_ug: 2.4 # was 16.8 weekly
  folate_ug: 400        # was 2800 weekly

  # Minerals
  calcium_mg: 1000      # was 7000 weekly
  copper_mg: 0.9       # was 6.3 weekly
  iron_mg: 8           # was 56 weekly
  magnesium_mg: 400    # was 2800 weekly
  manganese_mg: 2.3    # was 16.1 weekly
  phosphorus_mg: 700   # was 4900 weekly
  potassium_mg: 3400   # was 23800 weekly
  selenium_ug: 55      # was 385 weekly
  sodium_mg: 1500      # was 10500 weekly
  zinc_mg: 11          # was 77 weekly

  # Other (MicronutrientProfile)
  fiber_g: 38          # was 266 weekly
  omega_3_g: 1.6       # was 11.2 weekly
  omega_6_g: 17        # was 119 weekly