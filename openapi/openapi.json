{
  "components": {
    "schemas": {
      "BudgetLevel": {
        "enum": [
          "cheap",
          "standard",
          "premium"
        ],
        "title": "BudgetLevel",
        "type": "string"
      },
      "DietaryFlag": {
        "enum": [
          "vegetarian",
          "vegan",
          "gluten_free",
          "dairy_free"
        ],
        "title": "DietaryFlag",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "IngredientMatchAcceptedItem": {
        "properties": {
          "confidence": {
            "title": "Confidence",
            "type": "number"
          },
          "normalized_name": {
            "title": "Normalized Name",
            "type": "string"
          },
          "original_query": {
            "title": "Original Query",
            "type": "string"
          }
        },
        "required": [
          "original_query",
          "normalized_name",
          "confidence"
        ],
        "title": "IngredientMatchAcceptedItem",
        "type": "object"
      },
      "IngredientMatchRejectedItem": {
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "original_query": {
            "title": "Original Query",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "original_query"
        ],
        "title": "IngredientMatchRejectedItem",
        "type": "object"
      },
      "IngredientMatchRequest": {
        "properties": {
          "queries": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "title": "Queries",
            "type": "array"
          }
        },
        "required": [
          "queries"
        ],
        "title": "IngredientMatchRequest",
        "type": "object"
      },
      "IngredientMatchResponse": {
        "properties": {
          "accepted": {
            "items": {
              "$ref": "#/components/schemas/IngredientMatchAcceptedItem"
            },
            "title": "Accepted",
            "type": "array"
          },
          "rejected": {
            "items": {
              "$ref": "#/components/schemas/IngredientMatchRejectedItem"
            },
            "title": "Rejected",
            "type": "array"
          }
        },
        "required": [
          "accepted",
          "rejected"
        ],
        "title": "IngredientMatchResponse",
        "type": "object"
      },
      "IngredientResolveRequest": {
        "description": "Resolve by USDA id or by canonical name (+ ingredient source).",
        "properties": {
          "fdc_id": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Fdc Id"
          },
          "ingredient_source": {
            "anyOf": [
              {
                "pattern": "^(local|api)$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ingredient Source"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          }
        },
        "title": "IngredientResolveRequest",
        "type": "object"
      },
      "IngredientSearchResponse": {
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/IngredientSearchResultItem"
            },
            "title": "Results",
            "type": "array"
          }
        },
        "required": [
          "results"
        ],
        "title": "IngredientSearchResponse",
        "type": "object"
      },
      "IngredientSearchResultItem": {
        "properties": {
          "description": {
            "title": "Description",
            "type": "string"
          },
          "fdc_id": {
            "title": "Fdc Id",
            "type": "string"
          },
          "score": {
            "title": "Score",
            "type": "number"
          }
        },
        "required": [
          "fdc_id",
          "description",
          "score"
        ],
        "title": "IngredientSearchResultItem",
        "type": "object"
      },
      "NutritionIngredientLine": {
        "properties": {
          "name": {
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "quantity": {
            "minimum": 0.0,
            "title": "Quantity",
            "type": "number"
          },
          "unit": {
            "minLength": 1,
            "title": "Unit",
            "type": "string"
          }
        },
        "required": [
          "name",
          "quantity",
          "unit"
        ],
        "title": "NutritionIngredientLine",
        "type": "object"
      },
      "NutritionSummaryRequest": {
        "properties": {
          "ingredients": {
            "items": {
              "$ref": "#/components/schemas/NutritionIngredientLine"
            },
            "minItems": 1,
            "title": "Ingredients",
            "type": "array"
          },
          "servings": {
            "default": 1,
            "minimum": 1.0,
            "title": "Servings",
            "type": "integer"
          }
        },
        "required": [
          "ingredients"
        ],
        "title": "NutritionSummaryRequest",
        "type": "object"
      },
      "PlanFromTextRequest": {
        "properties": {
          "cost_level": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/BudgetLevel"
              },
              {
                "type": "null"
              }
            ]
          },
          "cuisine": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cuisine"
          },
          "dietary_flags": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/DietaryFlag"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dietary Flags"
          },
          "ingredient_source": {
            "default": "local",
            "pattern": "^(local|api)$",
            "title": "Ingredient Source",
            "type": "string"
          },
          "planning_mode": {
            "anyOf": [
              {
                "enum": [
                  "deterministic",
                  "assisted",
                  "assisted_cached",
                  "assisted_live"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Planning Mode"
          },
          "prep_time_bucket": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PrepTimeBucket"
              },
              {
                "type": "null"
              }
            ]
          },
          "prompt": {
            "minLength": 1,
            "title": "Prompt",
            "type": "string"
          },
          "recipe_tags_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipe Tags Path"
          }
        },
        "required": [
          "prompt"
        ],
        "title": "PlanFromTextRequest",
        "type": "object"
      },
      "PlanRequest": {
        "properties": {
          "allergies": {
            "items": {
              "type": "string"
            },
            "title": "Allergies",
            "type": "array"
          },
          "cost_level": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/BudgetLevel"
              },
              {
                "type": "null"
              }
            ]
          },
          "cuisine": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cuisine"
          },
          "daily_calories": {
            "title": "Daily Calories",
            "type": "integer"
          },
          "daily_fat_g_max": {
            "title": "Daily Fat G Max",
            "type": "number"
          },
          "daily_fat_g_min": {
            "title": "Daily Fat G Min",
            "type": "number"
          },
          "daily_protein_g": {
            "title": "Daily Protein G",
            "type": "number"
          },
          "days": {
            "default": 1,
            "maximum": 7.0,
            "minimum": 1.0,
            "title": "Days",
            "type": "integer"
          },
          "dietary_flags": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/DietaryFlag"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dietary Flags"
          },
          "disliked_foods": {
            "items": {
              "type": "string"
            },
            "title": "Disliked Foods",
            "type": "array"
          },
          "ingredient_source": {
            "default": "local",
            "pattern": "^(local|api)$",
            "title": "Ingredient Source",
            "type": "string"
          },
          "liked_foods": {
            "items": {
              "type": "string"
            },
            "title": "Liked Foods",
            "type": "array"
          },
          "micronutrient_goals": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Micronutrient Goals"
          },
          "micronutrient_weekly_min_fraction": {
            "default": 1.0,
            "exclusiveMinimum": 0.0,
            "maximum": 1.0,
            "title": "Micronutrient Weekly Min Fraction",
            "type": "number"
          },
          "planning_mode": {
            "anyOf": [
              {
                "enum": [
                  "deterministic",
                  "assisted",
                  "assisted_cached",
                  "assisted_live"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Planning Mode"
          },
          "prep_time_bucket": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PrepTimeBucket"
              },
              {
                "type": "null"
              }
            ]
          },
          "recipe_ids": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipe Ids"
          },
          "recipe_tags_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipe Tags Path"
          },
          "schedule": {
            "additionalProperties": {
              "type": "integer"
            },
            "title": "Schedule",
            "type": "object"
          }
        },
        "required": [
          "daily_calories",
          "daily_protein_g",
          "daily_fat_g_min",
          "daily_fat_g_max",
          "schedule"
        ],
        "title": "PlanRequest",
        "type": "object"
      },
      "PrepTimeBucket": {
        "enum": [
          "snack",
          "quick_meal",
          "weeknight_meal",
          "meal_prep"
        ],
        "title": "PrepTimeBucket",
        "type": "string"
      },
      "RecipeGenerationFailure": {
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "RecipeGenerationFailure",
        "type": "object"
      },
      "RecipeGenerationRequest": {
        "properties": {
          "context": {
            "additionalProperties": true,
            "title": "Context",
            "type": "object"
          },
          "count": {
            "maximum": 20.0,
            "minimum": 1.0,
            "title": "Count",
            "type": "integer"
          }
        },
        "required": [
          "context",
          "count"
        ],
        "title": "RecipeGenerationRequest",
        "type": "object"
      },
      "RecipeGenerationResponse": {
        "properties": {
          "accepted_count": {
            "title": "Accepted Count",
            "type": "integer"
          },
          "failures": {
            "items": {
              "$ref": "#/components/schemas/RecipeGenerationFailure"
            },
            "title": "Failures",
            "type": "array"
          },
          "recipe_ids": {
            "items": {
              "type": "string"
            },
            "title": "Recipe Ids",
            "type": "array"
          },
          "rejected_count": {
            "title": "Rejected Count",
            "type": "integer"
          }
        },
        "required": [
          "accepted_count",
          "rejected_count",
          "recipe_ids",
          "failures"
        ],
        "title": "RecipeGenerationResponse",
        "type": "object"
      },
      "RecipeSyncIngredientLine": {
        "description": "One ingredient line as sent by the client.",
        "properties": {
          "name": {
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "quantity": {
            "minimum": 0.0,
            "title": "Quantity",
            "type": "number"
          },
          "unit": {
            "minLength": 1,
            "title": "Unit",
            "type": "string"
          }
        },
        "required": [
          "name",
          "quantity",
          "unit"
        ],
        "title": "RecipeSyncIngredientLine",
        "type": "object"
      },
      "RecipeSyncItem": {
        "properties": {
          "cooking_time_minutes": {
            "default": 0,
            "minimum": 0.0,
            "title": "Cooking Time Minutes",
            "type": "integer"
          },
          "id": {
            "minLength": 1,
            "title": "Id",
            "type": "string"
          },
          "ingredients": {
            "items": {
              "$ref": "#/components/schemas/RecipeSyncIngredientLine"
            },
            "minItems": 1,
            "title": "Ingredients",
            "type": "array"
          },
          "instructions": {
            "items": {
              "type": "string"
            },
            "title": "Instructions",
            "type": "array"
          },
          "name": {
            "minLength": 1,
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "ingredients"
        ],
        "title": "RecipeSyncItem",
        "type": "object"
      },
      "RecipeSyncRequest": {
        "properties": {
          "recipes": {
            "items": {
              "$ref": "#/components/schemas/RecipeSyncItem"
            },
            "title": "Recipes",
            "type": "array"
          }
        },
        "required": [
          "recipes"
        ],
        "title": "RecipeSyncRequest",
        "type": "object"
      },
      "RecipeSyncResponse": {
        "properties": {
          "errors": {
            "items": {
              "type": "string"
            },
            "title": "Errors",
            "type": "array"
          },
          "synced_ids": {
            "items": {
              "type": "string"
            },
            "title": "Synced Ids",
            "type": "array"
          }
        },
        "required": [
          "synced_ids"
        ],
        "title": "RecipeSyncResponse",
        "type": "object"
      },
      "RecipeTagGenerationRequest": {
        "properties": {
          "llm_enabled": {
            "default": false,
            "title": "Llm Enabled",
            "type": "boolean"
          },
          "recipe_tags_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipe Tags Path"
          },
          "recipes_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
